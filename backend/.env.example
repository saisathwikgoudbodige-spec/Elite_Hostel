PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/hostel-db?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/hostel-fee-manager
JWT_SECRET=your_super_jwt_secret_key_for_signing_tokens
AADHAAR_ENCRYPTION_KEY=your_secure_32_character_key_for_aadhaar_encryption
FRONTEND_URL=https://your-frontend-url.vercel.app
NODE_ENV=development
# Optional: set VERCEL_URL on Vercel frontends if the backend should trust the deployed frontend host
# VERCEL_URL=your-frontend-app.vercel.app
